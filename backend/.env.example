# Server Port
PORT=5000

# JWT Secret Key
JWT_SECRET=your_jwt_secret_key

# Frontend URL (for redirects and reset links)
# In production, this might be your Netlify URL
FRONTEND_URL=http://localhost:5174

# Paytm Merchant Details
PAYTM_MERCHANT_ID=YOUR_PAYTM_MERCHANT_ID
PAYTM_MERCHANT_KEY=YOUR_PAYTM_MERCHANT_KEY
PAYTM_WEBSITE=WEBSTAGING
# Set to 'securegw.paytm.in' for production, 'securegw-stage.paytm.in' for testing
PAYTM_ENVIRONMENT=securegw-stage.paytm.in
PAYTM_CALLBACK_URL=http://localhost:5000/api/payment/callback
